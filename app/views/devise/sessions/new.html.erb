<%# app/views/devise/sessions/new.html.erb %>
<h2 class="form-title">ログイン</h2>

<div class="form-page">
  <div class="form">

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-group">
        <%= f.label :email, "メールアドレス", class: "form-label form_label--required" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "メールアドレスを入力" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "パスワード", class: "form-label form_label--required" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "パスワードを入力" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="remember-me">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "ログイン状態を保存する" %>
        </div>
      <% end %>

      <div class="form-actions">
        <%= f.submit "ログイン", class: "form-btn form-btn--primary" %>

        <%= link_to "新規登録はこちら",
            new_registration_path(resource_name),
            class: "form-btn form-btn--secondary" %>
      </div>

    <% end %> <!-- ← formここでちゃんと閉じる -->

    <!-- 👇 formの外に出す -->
    <div class="form-actions">
      <%= button_to "ゲストログイン",
          users_guest_sign_in_path,
          method: :post,
          class: "form-btn form-btn--secondary" %>
    </div>

    <div class="form-links">
      <% if devise_mapping.recoverable? && controller_name != "passwords" %>
        <%= link_to "パスワードを忘れた方はこちら",
            new_password_path(resource_name) %>
      <% end %>
    </div>

  </div>
</div>