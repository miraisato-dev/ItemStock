<%# app/views/devise/registrations/new.html.erb %>
<h1 class="form-title">新規登録</h1>

<div class="form-page">
  <div class="form">

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :email, "メールアドレス", class: "form-label form_label--required" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "メールアドレスを入力" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "パスワード", class: "form-label form_label--required" %>

        <% if @minimum_password_length %>
          <p class="password-hint">（<%= @minimum_password_length %>文字以上）</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "パスワードを入力" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "確認用パスワード", class: "form-label form_label--required" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "確認用パスワードを入力" %>
      </div>

      <div class="form-actions">
        <%= f.submit "新しいアカウントを作成", class: "form-btn form-btn--primary" %>

        <%= link_to "アカウントをお持ちの方はログイン",
            new_session_path(resource_name),
            class: "form-btn form-btn--secondary" %>
      </div>

    <% end %>

  </div>
</div>