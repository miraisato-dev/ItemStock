<%# app/views/devise/password/new.html.erb %>
<h2>パスワードを忘れた方</h2>

<div class="form">

<%= form_for(resource, as: resource_name, url: password_path(resource_name)) do |f| %>

  <div class="form-group">
    <%= f.label :email, "メールアドレス" %>
    <%= f.email_field :email, class: "form-control" %>
  </div>

  <div class="form-actions">
    <%= f.submit "送信", class: "form-btn form-btn--primary" %>
  </div>

<% end %>

<div class="form-actions">
  <%= link_to "ログインに戻る", new_user_session_path, class: "form-btn form-btn--secondary" %>
</div>

</div>