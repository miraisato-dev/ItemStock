<%# app/views/items/index.html.erb %>
<h1>持ち物一覧</h1>

<%= form_with url: items_path, method: :get, local: true, class: "search-box" do |f| %>

  <%= f.text_field :keyword, placeholder: "商品名検索" %>

  <%= f.select :status, Item.statuses.keys, include_blank: "ステータス" %>

  <%= f.select :category, Item.categories.keys, include_blank: "カテゴリ" %>

  <%= f.submit "検索" %>

<% end %>

<div class="table-wrapper">
  <table class="items-table">

<thead>
  <tr>
    <th>画像</th>
    <th>商品名</th>
    <th>カテゴリー</th>
    <th>値段</th>
    <th>ステータス</th>
    <th>出品日</th>
    <th>操作</th>
  </tr>
</thead>

<tbody>
  <% @items.each do |item| %>
    <tr>

      <td class="item-image">
        <% if item.images.attached? %>
          <%= image_tag item.images.first, width: 60 %>
        <% else %>
          画像なし
        <% end %>
      </td>

      <td class="item-name">
        <%= link_to item.name, item_path(item), class: "link-text" %>
      </td>

      <td class="item-category">
        <%= item.category %>
      </td>

      <td class="price">
        <%= number_to_currency(item.price, unit: "¥", precision: 0) %>
      </td>

    </tr>
  <% end %>
</tbody>

  </table>
</div>

</table>
</div>

<br>

<%= link_to "アイテム追加", new_item_path, class: "new-button" %>
