<%# app/views/items/_item.html.erb %>
<div class="item-detail">
  <div class="item-detail-container">

    <div class="item-thumbnails">
      <% item.images.each do |image| %>
        <%= image_tag image %>
      <% end %>
    </div>

    <div class="item-main-image">
      <%= image_tag item.images.first if item.images.attached? %>
    </div>

    <div class="item-info">
      <p><strong>商品タイトル:</strong> <%= item.name %></p>
      <p><strong>説明:</strong> <%= item.description %></p>
      <p><strong>値段:</strong> ¥<%= item.price %></p>
      <p><strong>ステータス:</strong>
        <span class="status-badge"><%= item.status %></span>
      </p>
      <p><strong>メモ:</strong> <%= item.memo %></p>

      <div class="item-actions">
        <%= link_to "編集", edit_item_path(item), class: "btn-edit" %>
        <%= button_to "削除", item,
          method: :delete,
          class: "btn-delete",
          onclick: "return confirm('本当に削除しますか？')" %>
      </div>
    </div>
  </div>
</div>